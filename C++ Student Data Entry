#include <iostream>
#include <string>
using namespace std;

struct Student {
    string name;
    int age;
};

int main() {
    Student students[3];

    for (int i = 0; i < 3; i++) {
        cout << "Enter student name: ";
        cin >> students[i].name;

        cout << "Enter student age: ";
        cin >> students[i].age;
    }

    cout << "\nStudent List:\n";

    for (int i = 0; i < 3; i++) {
        cout << "Name: " << students[i].name
             << " | Age: " << students[i].age << endl;
    }

    return 0;
}
